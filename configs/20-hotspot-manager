#!/bin/bash
# Smart Hotspot Manager - Event based, NO polling

set -euo pipefail

LOG_FILE="/var/log/hotspot-manager.log"
VPN_UUID="pi"

log_message() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> "$LOG_FILE"
}

if [ "${1:-}" != "eth0" ]; then
    exit 0
fi

case "${2:-}" in
    "up")
        (
            log_message "eth0 connected, checking network..."
            sleep 5

            if ping -c 2 -W 3 8.8.8.8 >/dev/null 2>&1; then
                log_message "Internet available"
                CLIENTS="$(iw dev wlan0 station dump 2>/dev/null | awk '/Station/ {count++} END {print count + 0}')"
                if [ "$CLIENTS" -gt 0 ]; then
                    log_message "Clients connected ($CLIENTS), ensuring VPN policy..."
                    if nmcli -t -f NAME,TYPE connection show --active | grep -qx "$VPN_UUID:vpn"; then
                        /etc/NetworkManager/dispatcher.d/90-hotspot-vpn-policy tun0 up >> "$LOG_FILE" 2>&1 || true
                    else
                        log_message "VPN not active, connecting..."
                        nmcli connection up "$VPN_UUID" >> "$LOG_FILE" 2>&1
                        /etc/NetworkManager/dispatcher.d/90-hotspot-vpn-policy tun0 up >> "$LOG_FILE" 2>&1 || true
                    fi
                fi
            else
                log_message "No internet, renewing DHCP..."
                dhclient -v eth0 >> "$LOG_FILE" 2>&1
            fi
        ) &
        ;;
esac
